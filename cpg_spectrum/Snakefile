# CpG mutation spectrum from population exome sites VCFs.
#
# One pipeline, two sources (see config.yaml):
#   - gnomad : v4.1 release sites VCFs, already VEP-annotated + chr-prefixed.
#   - rgc    : RGC Million Exomes frequency VCFs, unannotated + Ensembl-named
#              contigs (1..Y), so we rename to chr* and run Ensembl VEP here.
#
# Everything downstream of the +split-vep TSV (cpg_spectrum.py,
# refine_exon_boundary.py, summarize.R, the exon map) is source-agnostic.
#
# Run (gnomad needs no VEP; rgc does):
#   snakemake -j8 --config source=gnomad all
#   snakemake -j8 --use-envmodules --config source=rgc all
#
# Requirements: bcftools >=1.19 with +split-vep; a samtools-faidx'd, UNCOMPRESSED,
# chr-prefixed reference; for rgc, Ensembl VEP + a GRCh38 offline cache (README).

configfile: "config.yaml"

# --- resolve the active source --------------------------------------------

SOURCE = config["source"]
if SOURCE not in config["sources"]:
    raise ValueError(f"source {SOURCE!r} not in config['sources']")
S = config["sources"][SOURCE]

REF = config["ref"]
EXON_MAP = config["exon_map"]
VCF_TEMPLATE = S["vcf_template"]
AC_FIELD = S["ac_field"]
CSQ_TAG = S["csq_tag"]
CHRMAP = "data/ens2ucsc_chrs.txt"

CHROMS = [f"chr{c}" for c in list(range(1, 23)) + ["X", "Y"]]

# bcftools +split-vep output: 13 cols in the exact order cpg_spectrum.py expects.
SPLIT_VEP_FMT = (
    r"%CHROM\t%POS\t%REF\t%ALT\t%INFO/" + AC_FIELD +
    r"\t%Gene\t%SYMBOL\t%Feature\t%BIOTYPE\t%Consequence"
    r"\t%CANONICAL\t%MANE_SELECT\t%Codons\n"
)

# bcftools -i include expression: biallelic C/G SNVs, plus any source extra.
INCLUDE = 'REF="C" || REF="G"'
if S.get("include_extra"):
    INCLUDE = f'({INCLUDE}) && ({S["include_extra"]})'

# The .fai reader in cpg_spectrum.py seeks by byte offset, which only works on a
# plain (uncompressed) FASTA. Reject a compressed reference up front.
if REF.endswith((".gz", ".bgz", ".bz2")):
    raise ValueError(
        f"ref must be an uncompressed FASTA (cpg_spectrum.py cannot seek into "
        f"compressed files); got {REF!r}. Decompress first, e.g. `bgzip -d {REF}`."
    )


# --- targets ---------------------------------------------------------------

rule all:
    input:
        "variant_level.tsv",
        "gene_level.refined.tsv",
        "summary/spectrum.png",


# Build the .fai index the plain-Python FASTA reader needs (no-op if current).
rule faidx:
    input:
        REF,
    output:
        REF + ".fai",
    conda:
        "envs/cpg.yaml"
    shell:
        "samtools faidx {input}"


# Normalize to the analysis-ready record set: (optionally) rename contigs to
# chr*, split multiallelics, then keep PASS biallelic C/G SNVs (+ any source
# extra filter). Restricting here keeps the downstream VEP input minimal. For
# gnomad this preserves the existing `vep` INFO field; for rgc the output is
# unannotated and feeds the VEP rule.
rule prep_chrom:
    input:
        vcf=VCF_TEMPLATE,
        ref=REF,
        fai=REF + ".fai",
        chrmap=(CHRMAP if S["rename_chrs"] else []),
    output:
        temp("prepped/{chrom}.vcf.gz"),
    params:
        rename=(f"bcftools annotate --rename-chrs {CHRMAP} | " if S["rename_chrs"] else ""),
    conda:
        "envs/cpg.yaml"
    shell:
        r"""
        bcftools view {input.vcf} \
        | {params.rename}bcftools norm -m- -f {input.ref} \
        | bcftools view -f PASS -v snps -i '{INCLUDE}' \
        | bgzip > {output}
        """


# Annotate with Ensembl VEP (rgc only). --fields emits exactly the CSQ subfields
# cpg_spectrum.py parses; --synonyms lets the Ensembl cache resolve chr* names.
# Prefer the cluster module (--use-envmodules); envs/vep.yaml is a conda fallback.
if S["annotate"]:

    rule vep_chrom:
        input:
            vcf="prepped/{chrom}.vcf.gz",
            ref=REF,
        output:
            temp("annotated/{chrom}.vcf"),
        threads: config["vep"]["fork"]
        params:
            cache=config["vep"]["cache_dir"],
            release=config["vep"]["release"],
            synonyms=lambda wc: (
                f'{config["vep"]["cache_dir"]}/homo_sapiens/'
                f'{config["vep"]["release"]}_GRCh38/chr_synonyms.txt'
            ),
        conda:
            "envs/vep.yaml"
        envmodules:
            config["vep"]["module"],
        shell:
            r"""
            vep --offline --cache --dir_cache {params.cache} \
                --cache_version {params.release} --species homo_sapiens --assembly GRCh38 \
                --fasta {input.ref} --format vcf --vcf --no_stats --force_overwrite \
                --fork {threads} --buffer_size 20000 \
                --symbol --canonical --mane --biotype \
                --fields "Gene,SYMBOL,Feature,BIOTYPE,Consequence,CANONICAL,MANE_SELECT,Codons" \
                --synonyms {params.synonyms} \
                -i {input.vcf} -o STDOUT > {output}
            """


def classify_input(wildcards):
    """Annotated VCF if we ran VEP, else the prepped VCF (already carries CSQ)."""
    if S["annotate"]:
        return f"annotated/{wildcards.chrom}.vcf"
    return f"prepped/{wildcards.chrom}.vcf.gz"


# +split-vep expands per-transcript consequences; cpg_spectrum.py re-groups per
# variant, adds CpG context / substitution type, and classifies coding CpGs.
rule classify_chrom:
    input:
        vcf=classify_input,
        ref=REF,
        fai=REF + ".fai",
        script="scripts/cpg_spectrum.py",
    output:
        variant=temp("variant_level/{chrom}.tsv"),
        gene=temp("gene_level/{chrom}.tsv"),
    conda:
        "envs/cpg.yaml"
    shell:
        r"""
        bcftools +split-vep {input.vcf} -a {CSQ_TAG} -d -f '{SPLIT_VEP_FMT}' \
        | python3 {input.script} \
            --fasta {input.ref} \
            --variant-out {output.variant} \
            --gene-out {output.gene}
        """


def _merge(inputs, output):
    # concatenate per-chrom TSVs, keeping a single header
    shell("awk 'FNR==1 && NR!=1 {{next}} 1' " + " ".join(inputs) + " > " + output)


rule merge_variant:
    input:
        expand("variant_level/{chrom}.tsv", chrom=CHROMS),
    output:
        "variant_level.tsv",
    run:
        _merge(input, output[0])


rule merge_gene:
    input:
        expand("gene_level/{chrom}.tsv", chrom=CHROMS),
    output:
        "gene_level.tsv",
    run:
        _merge(input, output[0])


# Reclassify coding CpGs whose partner base is intronic (CpG straddles an
# exon/intron junction) from split/single_codon to exon_boundary.
rule refine_exon_boundary:
    input:
        gene="gene_level.tsv",
        exon_map=EXON_MAP,
        script="scripts/refine_exon_boundary.py",
    output:
        "gene_level.refined.tsv",
    conda:
        "envs/cpg.yaml"
    shell:
        "python3 {input.script} "
        "--gene-tsv {input.gene} --exon-map {input.exon_map} --out {output}"


# Tidyverse summaries + spectrum plot. The R script reads its paths from the
# Snakemake `script:` object, so don't list scripts/summarize.R in `input`
# (Snakemake re-runs this rule automatically when the script changes).
rule summarize:
    input:
        variant="variant_level.tsv",
        gene="gene_level.refined.tsv",
    output:
        spectrum="summary/spectrum_by_context.tsv",
        singletons="summary/spectrum_singletons.tsv",
        consequence="summary/spectrum_by_consequence.tsv",
        codon="summary/codon_class.tsv",
        plot="summary/spectrum.png",
    conda:
        "envs/summarize.yaml"
    script:
        "scripts/summarize.R"
